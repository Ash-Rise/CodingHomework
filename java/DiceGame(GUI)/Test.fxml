                  <Rectangle2D height="140.0" minX="50.0" minY="45.0" width="140.0" />
               </viewport></ImageView>
            <ImageView fx:id="die2Image" fitHeight="250.0" fitWidth="172.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@dice.png" />
               </image>
               <viewport>
                  <Rectangle2D height="140.0" minX="240.0" minY="230.0" width="140.0" />
               </viewport></ImageView>
         </children>
      </HBox>
